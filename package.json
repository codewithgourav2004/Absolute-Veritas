{
  "name": "absolute-veritas",
  "version": "1.0.0",
  "description": "Absolute Veritas TIC & IT Compliance Consultancy Website",
  "scripts": {
    "predev": "node scripts/kill-ports.js",
    "dev": "concurrently --names \"SERVER,CLIENT\" --prefix-colors \"yellow,cyan\" \"npm run server\" \"npm run client\"",
    "start": "npm run dev",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install",
    "build": "cd client && npm run build",
    "kill": "node scripts/kill-ports.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
